{
  "productName": "Pelagos",
  "version": "0.1.4",
  "identifier": "io.pelagos.ui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Pelagos",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libayatana-appindicator3-1",
          "libwebkit2gtk-4.1-0"
        ]
      }
    }
  }
}
